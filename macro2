Sub ExportExcelToJSON_Groupe()

    Dim ws As Worksheet
    Dim lastRow As Long, i As Long
    Dim lot As String, version As String
    Dim analyseBrut As String, analyseTexte As String
    Dim dict As Object, lotDict As Object, verDict As Object
    Dim regex As Object
    Dim json As String
    
    Set ws = ThisWorkbook.Sheets("EnCours")
    lastRow = ws.Cells(ws.Rows.Count, "B").End(xlUp).Row
    
    Set dict = CreateObject("Scripting.Dictionary")
    Set regex = CreateObject("VBScript.RegExp")
    
    regex.Pattern = "^\^"
    regex.IgnoreCase = True
    
    lot = ""
    
    For i = 2 To lastRow
    
        '--- Détection du Lot ---
        If Trim(ws.Cells(i, 2).Value) <> "" Then
            If Not regex.Test(ws.Cells(i, 2).Value) Then
                lot = Trim(ws.Cells(i, 2).Value)
                
                If Not dict.Exists(lot) Then
                    Set lotDict = CreateObject("Scripting.Dictionary")
                    dict.Add lot, lotDict
                Else
                    Set lotDict = dict(lot)
                End If
            End If
        End If
        
        If lot = "" Then GoTo LigneSuivante
        
        analyseBrut = CStr(ws.Cells(i, 4).Value)
        
        If InStr(analyseBrut, ":") > 0 Then
        
            version = Trim(Split(analyseBrut, ":")(0))
            If version = "" Then version = "NewLot"
            
            analyseTexte = Trim(Split(analyseBrut, ":")(1))
            analyseTexte = Replace(analyseTexte, vbLf, "\n")
            analyseTexte = Replace(analyseTexte, """", "\""")
            analyseTexte = Replace(analyseTexte, "'", "\'")
            
            Set verDict = CreateObject("Scripting.Dictionary")
            
            verDict.Add "Ancienne version", ws.Cells(i, 6).Value
            verDict.Add "Analyse", analyseTexte
            verDict.Add "TicketInstallation", ws.Cells(i, 5).Value
            verDict.Add "Date d'analyse", ws.Cells(i, 7).Value
            verDict.Add "TicketOuvert", Split(CStr(ws.Cells(i, 8).Value), ",")
            verDict.Add "TicketFerme", Split(CStr(ws.Cells(i, 10).Value), ",")
            verDict.Add "Statut", ws.Cells(i, 9).Value
            verDict.Add "TRI", ws.Cells(i, 11).Value
            
            If lotDict.Exists(version) Then
                lotDict(version) = verDict
            Else
                lotDict.Add version, verDict
            End If
            
        End If
        
LigneSuivante:
    
    Next i
    
    json = DictToJSON(dict, 1)
    
    '--- Sauvegarde ---
    Dim fName As Variant
    fName = Application.GetSaveAsFilename( _
                InitialFileName:="export.json", _
                FileFilter:="Fichiers JSON (*.json), *.json", _
                Title:="Enregistrer sous...")
    
    If fName <> False Then
        Dim fso As Object, ts As Object
        Set fso = CreateObject("Scripting.FileSystemObject")
        Set ts = fso.CreateTextFile(fName, True, True)
        ts.Write json
        ts.Close
        MsgBox "Export terminé : " & fName
    Else
        MsgBox "Export annulé"
    End If

End Sub


Function DictToJSON(d As Object, Optional indent As Integer = 0) As String

    Dim k As Variant
    Dim tmp As String
    Dim sp As String
    
    sp = String(indent * 4, " ")
    
    tmp = "{"
    
    For Each k In d.Keys
    
        tmp = tmp & vbCrLf & sp & """" & k & """:"
        
        If IsObject(d(k)) Then
        
            tmp = tmp & DictToJSON(d(k), indent + 1) & ","
            
        ElseIf IsArray(d(k)) Then
        
            tmp = tmp & "["
            Dim i As Long
            For i = LBound(d(k)) To UBound(d(k))
                tmp = tmp & """" & Trim(d(k)(i)) & """"
                If i < UBound(d(k)) Then tmp = tmp & ","
            Next
            tmp = tmp & "],"
            
        Else
        
            tmp = tmp & """" & Replace(CStr(d(k)), """", "\""") & ""","
            
        End If
        
    Next
    
    If Right(tmp, 1) = "," Then tmp = Left(tmp, Len(tmp) - 1)
    
    tmp = tmp & vbCrLf & String((indent - 1) * 4, " ") & "}"
    
    DictToJSON = tmp

End Function
